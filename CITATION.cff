    given-names: Matthew
    affiliation: "Nanosystems Lab, University of Hawaiʻi at Mānoa"
repository-code: "https://github.com/nanosystemslab/OpenPauw"
license: GPL-3.0
version: "1.4.0"
date-released: "2026-06-13"
keywords:
  - van-der-pauw
  - sheet-resistance
  - resistivity
  - instrumentation
  - rp2040
  - kicad
  - embedded
